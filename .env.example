# ══════════════════════════════════════════════════════════════════════════════
# Nuviie Hub — Variáveis de Ambiente
# Copie este arquivo para .env e ajuste os valores:
#   copy .env.example .env   (Windows)
#   cp .env.example .env     (Linux/Mac)
# ══════════════════════════════════════════════════════════════════════════════

# ── Django (obrigatório em produção) ─────────────────────────────────────────
# Gere uma chave: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=sua-chave-secreta-aqui

# true = modo desenvolvimento | false = produção
DEBUG=true

# Hosts permitidos, separados por vírgula
ALLOWED_HOSTS=127.0.0.1,localhost

# Origens CORS permitidas (deixe vazio para desabilitar CORS aberto)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://meudominio.com

# ── Extensão Chrome Maps Extractor ───────────────────────────────────────────
# Token usado pela extensão para enviar leads ao Nuviie local (header X-Nuviie-Token)
NUVIIE_EXTENSION_TOKEN=seu-token-secreto-aqui
# Usuário Django que receberá os leads importados pela extensão
NUVIIE_EXTENSION_USER=admin

# ── Playwright / Scraper Google Maps ─────────────────────────────────────────
# Deixe VAZIO para auto-detectar (recomendado no Windows).
# Só defina se souber o caminho exato do ms-playwright no seu PC.
# PLAYWRIGHT_BROWSERS_PATH=C:\Users\SEU_USUARIO\AppData\Local\ms-playwright

# Timeout do scraper em segundos (padrão: 600). Regra: limit x 35s (10 leads ~ 350s)
MAPS_SCRAPER_TIMEOUT=600

# Pasta para screenshots de diagnóstico do scraper (opcional)
# NUVIIE_SCREENSHOT_DIR=D:\rascunho\Nuviie\tmp

# ── Ollama (Chat IA) ───────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=qwen2.5:7b

# ── WhatsApp OTP (Evolution API) ───────────────────────────────────────────────
# Deixe vazio para simular OTP no console (modo dev)
# EVOLUTION_API_URL=https://sua-evolution-api.com
# EVOLUTION_API_KEY=sua-api-key
# EVOLUTION_INSTANCE=nome-da-instancia
