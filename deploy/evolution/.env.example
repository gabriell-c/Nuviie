# Variáveis do Evolution API (copie para .env nesta pasta)
#   copy .env.example .env   (Windows)
#   cp .env.example .env     (Linux/Mac)

# Chave de acesso da API. ESTE valor é a sua EVOLUTION_API_KEY no .env do Nuviie.
# Gere uma forte: python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTHENTICATION_API_KEY=troque-por-uma-chave-forte

# Senha do Postgres (qualquer senha forte; só o container usa)
POSTGRES_PASSWORD=troque-esta-senha

# URL pública do próprio Evolution (use http://localhost:8080 em local;
# em produção, a URL pública atrás do Cloudflare Tunnel/Nginx).
SERVER_URL=http://localhost:8080
